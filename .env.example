# ============================================================
# QuizCraft AI  —  Environment Variable Reference
# ============================================================
#
# Copy relevant sections into:
#   backend/.env   (Flask backend)
#   frontend/.env  (Vite / React frontend)
#
# ============================================================
# backend/.env
# ============================================================
PORT=5000
FLASK_DEBUG=true

# Required: Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_real_key_here

# Sent in OpenRouter request headers (can be any URL)
SITE_URL=http://localhost:3000

# ============================================================
# frontend/.env
# ============================================================
#
# IMPORTANT: Leave VITE_API_URL empty so API calls go through
# the Vite proxy (/api → http://localhost:5000).
# Only set this if deploying to a different host/domain.
VITE_API_URL=
